# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/pocket_champion?retryWrites=true&w=majority

# Random secret, at least 32 characters. Example: use https://generate-random.org/string-generator
JWT_SECRET=replace_this_with_a_long_random_secret

# Optional initial admin created on first server start
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ChangeMe123!
ADMIN_DISPLAY_NAME=Admin
ADMIN_GAME_NAME=

# Optional
PORT=3000
